@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_LEFT_RIGHT()

title Secrets Management - C4 Container

System_Ext(k8s, "Kubernetes", "Runs application pods and service accounts")
System_Ext(vault, "Vault", "Central secret store")

System_Boundary(platform, "Payment Processing Platform") {
  Container(gateway, "API Gateway", "Container", "Uses OIDC client secret and webhook secret")
  Container(wallet, "Wallet Service", "Container", "Uses DB credentials")
  Container(transaction, "Transaction Service", "Container", "Uses provider API key and DB credentials")
  Container(query, "Payment Query Service", "Container", "Uses DB credentials")
  Container(vaultAgent, "Vault Agent Sidecar (per pod)", "Sidecar", "Auth to Vault and inject secrets for each workload")
}

Rel(k8s, vaultAgent, "Kubernetes service account identity", "K8s auth")
Rel(vaultAgent, vault, "Read secrets / dynamic creds", "HTTPS")
Rel(vaultAgent, gateway, "Inject current + previous secrets", "shared memory / file")
Rel(vaultAgent, wallet, "Inject DB credentials", "shared memory / file")
Rel(vaultAgent, transaction, "Inject provider API key, webhook secret, DB creds", "shared memory / file")
Rel(vaultAgent, query, "Inject DB credentials", "shared memory / file")

@enduml
