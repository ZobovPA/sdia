@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
LAYOUT_LEFT_RIGHT()

title Payment Processing Context Map

System_Boundary(bank, "Bank Bounded Contexts") {
  System(api, "API / Orchestration Context", "Внешний API, start saga, read requests")
  System(wallet, "Wallet Context", "Баланс, резерв, списание, компенсация")
  System(txn, "Transaction Context", "Внешний статус платежа, provider integration, timeout")
  System(callbacks, "Callback Context", "Приём provider callback, валидация, нормализация")
  System(query, "Query Context", "CQRS read-model: status, history")
}

System_Ext(provider, "External Provider", "Внешняя система, не bounded context банка")

Rel(api, wallet, "Customer/Supplier: reserveFunds", "sync command")
Rel(api, query, "Customer/Supplier: read API", "sync query")

Rel(wallet, txn, "Published Language: PaymentInitiated", "Kafka")
Rel(wallet, query, "Published Language: PaymentInitiated", "Kafka")

Rel(txn, wallet, "Published Language: PaymentCompleted / PaymentFailed", "Kafka")
Rel(txn, query, "Published Language: PaymentCompleted / PaymentFailed", "Kafka")

Rel(txn, provider, "Customer/Supplier: initiate payment", "sync HTTPS")
Rel(provider, callbacks, "Provider callback contract", "HTTPS callback")
Rel(callbacks, txn, "Anti-Corruption Layer: normalized provider result", "sync REST")

@enduml
