@startuml
skinparam componentStyle rectangle
left to right direction

title Payment Platform Context Map

rectangle "Customer Context\n(клиент, договоры, KYC)" as CUST
rectangle "Merchant Registry Context\n(мерчант, договор,\nendpoint, ключи)" as MER
rectangle "Wallet Context\n(кошельки, баланс,\nблокировки/holds)" as WLT
rectangle "Payments Context\n(жизненный цикл платежа)" as PAY
rectangle "Anti-Fraud / Scoring Context\n(решение риска: ALLOW/CHALLENGE/DENY)" as FRD
rectangle "Notifications Context\n(SMS/push/email)" as NTF
rectangle "Callbacks Context\n(уведомления мерчантам,\nгарантированная доставка)" as CB
rectangle "Analytics / DWH Context\n(витрины, audit stream,\nмодельные датасеты)" as ANL
rectangle "Provider Integration Context\n(карточный процессинг,\nСБП, др.)" as PRV
rectangle "Core Banking Context (Legacy)\n(бухгалтерия/GL)" as CORE
rectangle "ACL: Core Integration\n(translation, shielding,\nidempotency, mapping)" as ACL

CUST --> PAY : Customer/Supplier\nPL: Customer, KYC, ContractRef
CUST --> WLT : Customer/Supplier\nPL: ContractOpened
CUST --> FRD : Customer/Supplier\nPL: KycStatusChanged
MER --> PAY : Customer/Supplier\nmerchant profile, routing data
MER --> CB : Customer/Supplier\nconfig, keys, endpoints, retry policy

PAY --> FRD : Customer/Supplier\nsync: AssessRisk -> Decision

PAY --> WLT : Customer/Supplier\ncommands: PlaceHold/Commit/Release
WLT --> PAY : Published Language\nevents: HoldPlaced, WalletDebited

PAY --> PRV : Customer/Supplier\nPL: ProviderCommand
PRV --> PAY : Published Language\nProviderStatusChanged

PAY --> CB : Published Language\nPaymentStatusChanged
PAY --> NTF : Published Language\nPaymentStatusChanged
FRD --> NTF : Published Language\nChallengeRequired, FraudDenied
PAY --> ANL : Published Language\nPaymentCreated, PaymentStatusChanged
WLT --> ANL : Published Language\nBalanceChanged, HoldPlaced
FRD --> ANL : Published Language\nRiskAssessed
CB --> ANL : Published Language\nCallbackDelivered, CallbackFailed

PAY --> ACL : Customer/Supplier\nAccountingIntent
ACL --> CORE : Conformist\nlegacy API / protocol
CORE --> ACL : Conformist\nlegacy response
ACL --> PAY : Anti-Corruption Layer\ntranslated result

@enduml
