@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_LEFT_RIGHT()

title Payment Processing - C4 Container

Person(client, "Клиент", "Mobile / Web клиент")
System_Ext(provider, "External Provider", "Внешний платёжный провайдер")

System_Boundary(paymentPlatform, "Payment Processing Platform") {
  Container(gateway, "API Gateway", "HTTPS Gateway", "Маршрутизация внешних клиентских запросов и provider callback")
  Container(orchestrator, "Orchestrator / API", "REST", "Стартует платёжную сагу и читает статус из query-модели")

  Container_Boundary(walletBoundary, "Wallet Service") {
    Container(walletService, "Wallet Service", "REST + Kafka", "Проверка баланса, резерв, списание, компенсация")
    ContainerDb(walletDb, "Wallet DB", "PostgreSQL", "wallets, wallet_transactions, wallet_outbox")
  }

  Container_Boundary(transactionBoundary, "Transaction Service") {
    Container(transactionService, "Transaction Service", "REST + Kafka", "Технический статус платежа, интеграция с провайдером, timeout")
    ContainerDb(transactionDb, "Transaction DB", "PostgreSQL", "payments, provider_callbacks, payment_outbox")
  }

  Container_Boundary(callbackBoundary, "Callback Service") {
    Container(callbackService, "Callback Service", "REST", "Принимает callback-и провайдера, валидирует и нормализует payload")
  }

  Container_Boundary(queryBoundary, "Payment Query Service") {
    Container(queryService, "Payment Query Service", "REST + Kafka", "Строит read-модель платежей из событий")
    ContainerDb(queryDb, "Query DB", "PostgreSQL", "payment_view, query_processed_events")
  }

  Container(kafka, "Kafka", "Message Broker", "PaymentInitiated, PaymentCompleted, PaymentFailed")
}

Rel(client, gateway, "Создание платежа, история, статус", "HTTPS")
Rel(provider, gateway, "Provider callback", "HTTPS")

Rel(gateway, orchestrator, "Client API", "REST")
Rel(gateway, callbackService, "Callback API", "REST")

Rel(orchestrator, walletService, "reserveFunds", "REST")
Rel(orchestrator, queryService, "GetPaymentStatus / GetUserPayments", "REST")

Rel(walletService, walletDb, "Чтение/запись")
Rel(walletService, kafka, "PaymentInitiated", "async")

Rel(kafka, transactionService, "PaymentInitiated", "async")
Rel(kafka, walletService, "PaymentCompleted / PaymentFailed", "async")
Rel(kafka, queryService, "PaymentInitiated / PaymentCompleted / PaymentFailed", "async")

Rel(transactionService, transactionDb, "Чтение/запись")
Rel(transactionService, provider, "Initiate payment", "HTTPS")
Rel(callbackService, transactionService, "POST /internal/provider-results", "REST")
Rel(transactionService, kafka, "PaymentCompleted / PaymentFailed", "async")

Rel(queryService, queryDb, "Чтение/запись")

@enduml
