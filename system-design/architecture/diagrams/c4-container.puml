@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_LEFT_RIGHT()

title Payment Platform - C4 Container

Person(customer, "Клиент банка")
System_Ext(merchantExt, "Мерчант / Партнёр")
System_Ext(idp, "OIDC Provider")
System_Ext(cardProcessing, "Карточный процессинг")
System_Ext(sbp, "СБП")
System_Ext(coreLegacy, "Core Banking (Legacy)")

System_Boundary(pp, "Платёжная платформа") {
  Container(kong, "Kong API Gateway", "Nginx + Lua", "OIDC/JWT, mTLS, rate limit, routing, correlation-id")
  Container(bff, "BFF / Mobile API", "REST", "Агрегация API для mobile/web")
  Container(payments, "Payments Service", "REST + gRPC + Events", "Жизненный цикл платежа и оркестрация")
  Container(wallet, "Wallet Service", "gRPC + Events", "Баланс, holds, списания")
  Container(fraud, "Anti-Fraud Service", "gRPC + Events", "Онлайн-оценка риска")
  Container(coreAcl, "Core Integration / ACL", "Events + sync adapters", "Изоляция legacy core")
  Container(notify, "Notifications Service", "Events", "SMS/push/email")
  Container(callbacks, "Callbacks Service", "Events + HTTP", "Доставка webhook-уведомлений мерчантам")
  Container(provider, "Provider Integration", "gRPC/REST + adapters", "Адаптеры карточного процессинга и СБП")

  Container(messageBus, "Kafka", "Event Streaming", "Доменные события, аналитика, аудит")
  Container(jobQueue, "RabbitMQ", "Queue", "Задачи доставки, повторы, ограничение скорости, batch")

  ContainerDb(paymentsDb, "Payments DB", "PostgreSQL", "Платежи, попытки, idempotency")
  ContainerDb(walletDb, "Wallet DB", "PostgreSQL", "Кошельки, holds, движения")
}

Rel(customer, kong, "HTTPS")
Rel(merchantExt, kong, "HTTPS + mTLS")
Rel(kong, idp, "OIDC validation", "HTTPS")

Rel(kong, bff, "/mobile/*", "HTTPS sync")
Rel(kong, payments, "/payments/*", "HTTPS sync")
Rel(kong, callbacks, "/merchant/*", "HTTPS sync")

Rel(bff, payments, "CreatePayment / GetStatus", "REST sync")
Rel(payments, wallet, "PlaceHold / Commit / Release", "gRPC sync")
Rel(payments, fraud, "AssessRisk", "gRPC sync")
Rel(payments, provider, "Authorize / Capture / Refund", "gRPC/REST sync")
Rel(payments, coreAcl, "Accounting intent", "async event / adapter call")

Rel(payments, paymentsDb, "reads/writes")
Rel(wallet, walletDb, "reads/writes")

Rel(payments, messageBus, "Payment events", "async")
Rel(wallet, messageBus, "Balance / hold events", "async")
Rel(messageBus, notify, "Consume payment/fraud events", "async")
Rel(messageBus, callbacks, "Consume PaymentStatusChanged", "async")
Rel(messageBus, fraud, "Consume signals for models", "async")
Rel(messageBus, coreAcl, "Consume AccountingRequested", "async")

Rel(callbacks, jobQueue, "Delivery jobs", "async")
Rel(jobQueue, callbacks, "Повторы и ограничение скорости", "async")

Rel(provider, cardProcessing, "Provider-specific API", "sync/async")
Rel(provider, sbp, "SBP API", "sync/async")
Rel(callbacks, merchantExt, "Webhook delivery", "HTTPS async")
Rel(coreAcl, coreLegacy, "Legacy API / protocol", "sync/async")

@enduml
